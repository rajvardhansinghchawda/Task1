# Template for environment variables (DO NOT PUT SECRETS HERE)
SECRET_KEY=your-django-secret-key
DEBUG=True

# Database Configuration
DB_NAME=hospital_hms
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Google Calendar Integration
GOOGLE_CALENDAR_REDIRECT_URI=http://127.0.0.1:8000/integrations/oauth2callback/

# Local Email Service
EMAIL_SERVICE_URL=http://localhost:3000/send-email
